<DeviceSettings>
    <Settings>
        <Group name="Device Information" expand="true">
            <Setting key="model" name="Model" type="string" readOnly="true"/>
            <Setting key="serial_number" name="Serial Number" type="string" readOnly="true"/>
            <Setting key="hardware_version" name="Hardware Version" type="string" readOnly="true"/>
            <Setting key="bootloader_version" name="Bootloader Version" type="string" readOnly="true"/>
            <Setting key="firmware_version" name="Firmware Version" type="string" readOnly="true"/>
            <Setting key="device_name" name="Device Name" type="string"/>
        </Group>
        <Group name="Serial" expand="true">
            <Setting key="serial_enabled" name="Enabled" type="bool"/>
            <Setting key="serial_baud_rate" name="Baud Rate" type="number" hideKey="serial_mode" hideValues="0"/>
            <Setting key="serial_rts_cts_enabled" name="RTS/CTS" type="bool" hideKey="serial_mode" hideValues="0"/>
        </Group>
        <Group name="ICM-45686" expand="true">
            <Setting key="sample_rate" name="Sample Rate" type="IcmSampleRate"/>
            <Group name="Low-Pass Filter" expand="true">
                <Setting key="gyroscope_low_pass_filter" name="Gyroscope" type="IcmLowPassFilter"/>
                <Setting key="accelerometer_low_pass_filter" name="Accelerometer" type="IcmLowPassFilter"/>
            </Group>
        </Group>
        <Group name="IMU" expand="true">
            <Setting key="axes_remap" name="Axes Remap" type="FusionRemapAlignment"/>
            <Setting key="gyroscope_bias_correction_enabled" name="Gyroscope Bias Correction" type="bool"/>
            <Group name="AHRS" expand="true">
                <Setting key="ahrs_update_rate_divisor" name="Update Rate Divisor" type="number"/>
                <Setting key="ahrs_axes_convention" name="Axes Convention" type="FusionConvention"/>
                <Setting key="ahrs_gain" name="Gain" type="number"/>
                <Setting key="ahrs_acceleration_rejection" name="Acceleration Rejection" type="number"/>
            </Group>
        </Group>
        <Group name="Data Messages" expand="true">
            <Setting key="data_message_mode" name="Mode" type="SendDataMessageMode"/>
            <Setting key="ahrs_message_type" name="AHRS Message Type" type="SendAhrsMessageType"/>
            <Group name="Message Rates" expand="true">
                <Setting key="inertial_message_rate_divisor" name="Inertial" type="number"/>
                <Setting key="ahrs_message_rate_divisor" name="AHRS" type="number"/>
                <Setting key="temperature_message_rate_divisor" name="Temperature" type="number"/>
            </Group>
            <Group name="Interfaces" expand="true">
                <Setting key="usb_send_mode" name="USB" type="SendInterfaceMode"/>
                <Setting key="serial_send_mode" name="Serial" type="SendInterfaceMode"/>
            </Group>
        </Group>
        <Margin/>
    </Settings>
    <Enums>
        <Enum name="FusionRemapAlignment">
            <Enumerator name="+X+Y+Z (Disabled)" value="0"/>
            <Enumerator name="+X-Z+Y" value="1"/>
            <Enumerator name="+X-Y-Z" value="2"/>
            <Enumerator name="+X+Z-Y" value="3"/>
            <Enumerator name="-X+Y-Z" value="4"/>
            <Enumerator name="-X+Z+Y" value="5"/>
            <Enumerator name="-X-Y+Z" value="6"/>
            <Enumerator name="-X-Z-Y" value="7"/>
            <Enumerator name="+Y-X+Z" value="8"/>
            <Enumerator name="+Y-Z-X" value="9"/>
            <Enumerator name="+Y+X-Z" value="10"/>
            <Enumerator name="+Y+Z+X" value="11"/>
            <Enumerator name="-Y+X+Z" value="12"/>
            <Enumerator name="-Y-Z+X" value="13"/>
            <Enumerator name="-Y-X-Z" value="14"/>
            <Enumerator name="-Y+Z-X" value="15"/>
            <Enumerator name="+Z+Y-X" value="16"/>
            <Enumerator name="+Z+X+Y" value="17"/>
            <Enumerator name="+Z-Y+X" value="18"/>
            <Enumerator name="+Z-X-Y" value="19"/>
            <Enumerator name="-Z+Y+X" value="20"/>
            <Enumerator name="-Z-X+Y" value="21"/>
            <Enumerator name="-Z-Y-X" value="22"/>
            <Enumerator name="-Z+X-Y" value="23"/>
        </Enum>
        <Enum name="FusionConvention">
            <Enumerator name="North-West-Up (NWU)" value="0"/>
            <Enumerator name="East-North-Up (ENU)" value="1"/>
            <Enumerator name="North-East-Down (NED)" value="2"/>
        </Enum>
        <Enum name="IcmSampleRate">
            <Enumerator name="12 Hz" value="12"/>
            <Enumerator name="25 Hz" value="25"/>
            <Enumerator name="50 Hz" value="50"/>
            <Enumerator name="100 Hz" value="100"/>
            <Enumerator name="200 Hz" value="200"/>
            <Enumerator name="400 Hz" value="400"/>
            <Enumerator name="800 Hz" value="800"/>
            <Enumerator name="1600 Hz" value="1600"/>
            <Enumerator name="3200 Hz" value="3200"/>
            <Enumerator name="6400 Hz" value="6400"/>
        </Enum>
        <Enum name="IcmLowPassFilter">
            <Enumerator name="Bypass" value="0"/>
            <Enumerator name="Sample Rate / 4" value="4"/>
            <Enumerator name="Sample Rate / 8" value="8"/>
            <Enumerator name="Sample Rate / 16" value="16"/>
            <Enumerator name="Sample Rate / 32" value="32"/>
            <Enumerator name="Sample Rate / 64" value="64"/>
            <Enumerator name="Sample Rate / 128" value="128"/>
        </Enum>
        <Enum name="SendAhrsMessageType">
            <Enumerator name="Quaternion" value="0"/>
            <Enumerator name="Rotation Matrix" value="1"/>
            <Enumerator name="Euler Angles" value="2"/>
            <Enumerator name="Linear Acceleration" value="3"/>
            <Enumerator name="Earth Acceleration" value="4"/>
        </Enum>
        <Enum name="SendDataMessageMode">
            <Enumerator name="Binary" value="0"/>
            <Enumerator name="ASCII" value="1"/>
        </Enum>
        <Enum name="SendInterfaceMode">
            <Enumerator name="Disabled" value="0"/>
            <Enumerator name="Blocking" value="1"/>
            <Enumerator name="Non-Blocking" value="2"/>
        </Enum>
    </Enums>
</DeviceSettings>
